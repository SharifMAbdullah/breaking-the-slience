","\n","    print(f\"Starting evaluation on {len(df_test)} samples...\")\n","    FastLanguageModel.for_inference(model) # Ensure 2x faster inference is active\n","\n","    for _, row in tqdm(df_test.iterrows(), total=len(df_test)):\n","        # 2. Prepare the Input (Match your training prompt exactly)\n","        source_text: str = str(row[\"text\"])\n","        # We leave 'target' empty to let the model complete the gloss\n","        prompt: str = (\n","            f\"### Instruction:\\nTranslate the Bangla sentence to Bangla Sign Language (BdSL) gloss.\\n\\n\"\n","            f\"### Input:\\n{source_text}\\n\\n\"\n","            f\"### Response:\\n\"\n","        )\n","\n","        inputs = tokenizer([prompt], return_tensors=\"pt\").to(\"cuda\")\n","\n","        # 3. Generate with constraints\n","        outputs = model.generate(\n","            **inputs,\n","            max_new_tokens=128,\n","            use_cache=True,\n","            pad_token_id=tokenizer.eos_token_id\n","        )\n","\n","        # 4. Extract only the generated Response\n","        full_output: str = tokenizer.batch_decode(outputs, skip_special_tokens=True)[0]\n","        # Split by the Response header to isolate the gloss\n","        if \"### Response:\\n\" in full_output:\n","            response: str = full_output.split(\"### Response:\\n\")[-1].strip()\n","        else:\n","            response: str = full_output.strip()\n","\n","        predictions.append(response)\n","        references.append([str(row[\"gloss\"])])\n","\n","    # 5. Compute Metrics\n","    bleu_results: Dict[str, Any] = bleu.compute(predictions=predictions, references=references)\n","    chrf_results: Dict[str, Any] = chrf.compute(predictions=predictions, references=references)\n","\n","    return {\n","        \"bleu_score\": bleu_results[\"bleu\"] * 100, # Scale to 0-100\n","        \"chrf_score\": chrf_results[\"score\"]       # Already 0-100\n","    }\n","\n","# Execution:\n","results = evaluate_on_test_set(\"/ka