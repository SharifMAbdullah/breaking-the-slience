{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPHWD93iWwER7fqVCXhQFE1"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"id":"nmq-YJHCTWGA"},"outputs":[],"source":["!pip install openai pandas sacrebleu"]},{"cell_type":"code","source":["PROMPT = f\"\"\"You are a linguistically careful assistant trained to generate Bangla Sign Language (BdSL) gloss approximations from Bangla sentences.\n","Your task is to learn the mapping pattern between Sentence → Gloss from the examples and then generate\n","the gloss for the given Bangla sentence.\n","\n","Strict instructions:\n","1. Use Bangla words, written in Bangla script.\n","2. Use the correct infinitive form of verbs wherever applicable\n","Example:\n","“কাজ করে” → “কাজ করা”\n","“গাইতে” → “গাওয়া”\n","3. Follow BdSL-preferred ordering as observed in the examples.\n","4. Do not paraphrase or add information.\n","5. Do not remove core meaning.\n","6. If a sentence is ambiguous, choose the most neutral, literal gloss.\n","7. No numbering, no quotes, no extra whitespace.\n","8. If the input sentence contains:\n","- multiple clauses\n","- temporal expressions\n","- conditionals\n","- negation\n","- modality\n","- questions\n","The gloss MUST preserve that complexity.\"\"\""],"metadata":{"id":"EmVpcT1uT7F4","executionInfo":{"status":"ok","timestamp":1773142800573,"user_tz":-360,"elapsed":46,"user":{"displayName":"Sharif Mohammad Abdullah","userId":"18125080519428770399"}}},"execution_count":2,"outputs":[]},{"cell_type":"code","source":["import pandas as pd\n","from openai import OpenAI\n","from typing import List, Dict, Optional, Any\n","import sacrebleu\n","import unittest\n","\n","class TranslationResult:\n","    def __init__(self, source: str, reference: str, translation: str):\n","        self.source: str = source\n","        self.reference: str = reference\n","        self.translation: str = translation\n","\n","\n","class GPTTranslator:\n","    def __init__(self, api_key: str, model: str = \"gpt-5.4\"):\n","        self.client: OpenAI = OpenAI(api_key=api_key)\n","        self.model: str = model\n","\n","    def translate_text(self, text: str) -> str:\n","        response: Any = self.client.chat.completions.create(\n","            model=self.model,\n","            messages=[\n","                {\"role\": \"user\", \"content\": \"দাদি আমাদের পুরানো দিনের গল্প শোনাতেন।\"},\n","                {\"role\": \"assistant\", \"content\": \"দাদি আমাদের পুরানো দিন গল্প শোনা\"},\n","                {\"role\": \"user\", \"content\": \"বাচ্চারা মিষ্টি খেতে খুব পছন্দ করে।\"},\n","                {\"role\": \"assistant\", \"content\": \"বাচ্চারা মিষ্টি খাওয়া পছন্দ\"},\n","                {\"role\": \"user\", \"content\": \"আপনি কি চা খাবেন?\"},\n","                {\"role\": \"assistant\", \"content\": \"আপনি চা খাওয়া\"},\n","                {\"role\": \"system\", \"content\": PROMPT},\n","                {\"role\": \"user\", \"content\": text},\n","            ],\n","            temperature=0\n","        )\n","        return str(response.choices[0].message.content).strip()\n","\n","class TranslationEvaluator:\n","    \"\"\"Calculates NLP metrics for translation quality.\"\"\"\n","\n","    @staticmethod\n","    def calculate_bleu(predictions: List[str], references: List[str]) -> float:\n","        \"\"\"Calculates BLEU score using sacrebleu.\"\"\"\n","        # sacrebleu expects a list of lists for references\n","        bleu: Any = sacrebleu.corpus_bleu(predictions, [references])\n","        return float(bleu.score)\n","\n","    @staticmethod\n","    def calculate_chrf(predictions: List[str], references: List[str]) -> float:\n","        \"\"\"Calculates chrF score using sacrebleu.\"\"\"\n","        chrf: Any = sacrebleu.corpus_chrf(predictions, [references])\n","        return float(chrf.score)\n","\n","\n","\n","def run_translation_pipeline(file_path: str, api_key: str) -> Dict[str, float]:\n","    # 1. Load Data\n","    df: pd.DataFrame = pd.read_csv(file_path)\n","\n","    # 2. Initialize Services\n","    translator: GPTTranslator = GPTTranslator(api_key=api_key)\n","    evaluator: TranslationEvaluator = TranslationEvaluator()\n","\n","    translations: List[str] = []\n","\n","    # 3. Process (Translation)\n","    print(f\"Translating {len(df)} rows using GPT-5.4...\")\n","    for text in df['text']:\n","        translated: str = translator.translate_text(str(text))\n","        translations.append(translated)\n","\n","    df['gpt_translation'] = translations\n","\n","    # 4. Evaluation\n","    references: List[str] = df['gloss'].astype(str).tolist()\n","\n","    bleu_score: float = evaluator.calculate_bleu(translations, references)\n","    chrf_score: float = evaluator.calculate_chrf(translations, references)\n","\n","    # Save results\n","    df.to_csv(\"translated_results.csv\", index=False)\n","\n","    return {\"BLEU\": bleu_score, \"chrF\": chrf_score}\n"],"metadata":{"id":"WAJKHJDiTdMp","executionInfo":{"status":"ok","timestamp":1773142906728,"user_tz":-360,"elapsed":20,"user":{"displayName":"Sharif Mohammad Abdullah","userId":"18125080519428770399"}}},"execution_count":5,"outputs":[]},{"cell_type":"code","source":["# User Input\n","from google.colab import userdata\n","API_KEY: str = userdata.get('OPENAI_API_BARTA')\n","\n","results = run_translation_pipeline(\"test.csv\", API_KEY)\n","print(f\"Results: {results}\")"],"metadata":{"id":"NMt44t5bThNr","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1773143052103,"user_tz":-360,"elapsed":144325,"user":{"displayName":"Sharif Mohammad Abdullah","userId":"18125080519428770399"}},"outputId":"ad7df7d5-8c5a-4b98-90b8-5dab43792494"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["Translating 159 rows using GPT-5.4...\n","Results: {'BLEU': 39.259102929928275, 'chrF': 73.748766819743