{"cells":[{"cell_type":"code","execution_count":null,"metadata":{"id":"IdkhpZCVMFkm"},"outputs":[],"source":["!pip install \"unsloth[colab-new] @ git+https://github.com/unslothai/unsloth.git\"\n","!pip install --no-deps \"xformers<0.0.27\" \"trl<0.9.0\" peft accelerate bitsandbytes"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"sBR9VOzfMMOs"},"outputs":[],"source":["from unsloth import FastLanguageModel\n","import torch\n","from datasets import load_dataset, Dataset\n","from trl import SFTTrainer\n","from transformers import TrainingArguments\n","import pandas as pd\n","from sklearn.model_selection import KFold\n","from torch.utils.data import Sampler, DataLoader\n","\n","# --- CONFIGURATION ---\n","model_name = \"unsloth/Qwen3-8B-unsloth-bnb-4bit\"\n","max_seq_length = 2048 # Supports up to 256k\n","dtype = None\n","load_in_4bit = True # Use 4bit to fit on most GPUs"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"o7CV6lz0MKCf"},"outputs":[],"source":["# 2. Load Model and Tokenizer\n","model, tokenizer = FastLanguageModel.from_pretrained(\n","    model_name = model_name,\n","    max_seq_length = max_seq_length,\n","    dtype = dtype,\n","    load_in_4bit = load_in_4bit,\n",")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"inM4V1FLMSU0"},"outputs":[],"source":["# 3. Add LoRA Adapters\n","model = FastLanguageModel.get_peft_model(\n","    model,\n","    r = 16, # Rank: higher = more parameters, better for complex logic\n","    target_modules = [\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\",\n","                      \"gate_proj\", \"up_proj\", \"down_proj\",],\n","    lora_alpha = 32,\n","    lora_dropout = 0,\n","    bias = \"none\",\n","    use_gradient_checkpointing = \"unsloth\",\n","    random_state = 3407,\n",")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"TFhFmmJgMUik"},"outputs":[],"source":["# 4. Data Preparation (Translation Format)\n","import pandas as pd\n","from typing import Dict, List\n","from datasets import DatasetDict\n","\n","def formatting_prompts_func(examples: Dict[str, List[str]]) -> Dict[str, List[str]]:\n","    inputs: List[str] = examples[\"text\"]\n","    outputs: List[str] = examples[\"gloss\"]\n","    EOS_TOKEN: str = tokenizer.eos_token # Must include EOS\n","\n","    formatted_texts: List[str] = []\n","    for source, target in zip(inputs, outputs):\n","        # Using a more structured separator\n","        text: str = (\n","            f\"### Instruction:\\nTranslate the Bangla sentence to Bangla Sign Language (BdSL) gloss.\\n\\n\"\n","            f\"### Input:\\n{source}\\n\\n\"\n","            f\"### Response:\\n{target}{EOS_TOKEN}\"\n","        )\n","        formatted_texts.append(text)\n","    return {\"text\": formatted_texts}\n","\n","# Load a sample dataset (replace with your own)\n","df_human = pd.read_csv(\"human.csv\")\n","df_synthetic = pd.read_csv(\"synthetic.csv\")\n","df_all = pd.concat([df_human, df_synthetic])\n","dataset = Dataset.from_pandas(df_all)\n","dataset = dataset.map(formatting_prompts_func, batched=True)\n","split_dataset: DatasetDict = dataset.train_test_split(\n","    test_size=0.2,\n","    seed=3407,\n",")\n","\n","train_dataset: Dataset = split_dataset[\"train\"]\n","val_dataset: Dataset = split_dataset[\"test\"]"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"FfNT2TY0MYVH"},"outputs":[],"source":["# 5. Set up Trainer\n","trainer = SFTTrainer(\n","    model = model,\n","    tokenizer = tokenizer,\n","    train_dataset=train_dataset,\n","    eval_dataset=val_dataset,\n","    dataset_text_field = \"text\",\n","    max_seq_length = max_seq_length,\n","    args = TrainingArguments(\n","        per_device_train_batch_size = 2,\n","        gradient_accumulation_steps = 4,\n","        warmup_steps = 50,\n","        num_train_epochs = 3, # Adjust based on dataset size\n","        learning_rate = 2e-4,\n","        fp16 = not torch.cuda.is_bf16_supported(),\n","        bf16 = torch.cuda.is_bf16_supported(),\n","        logging_steps = 50,\n","        logging_strategy = \"steps\",\n","        eval_strategy = \"steps\",\n","        eval_steps = 100,\n","        max_steps=1100,\n","        load_best_model_at_end = True,\n","        save_strategy = \"steps\",\n","        save_steps = 100,\n","        save_total_limit = 2,\n","        optim = \"adamw_8bit\",\n","        weight_decay = 0.01,\n","        lr_scheduler_type = \"linear\",\n","        seed = 3407,\n","        output_dir = \"outputs\",\n","    ),\n",")\n","\n"]},{"cell_type":"code","source":["# !rm -rf outputs"],"metadata":{"id":"BmiQvGBTZUwq"},"execution_count":null,"outputs":[]},{"cell_type":"code","execution_count":null,"metadata":{"id":"4WgXyHcRMaxY"},"outputs":[],"source":["# 6. Train!\n","trainer.train()"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"gXdhhBusMcLq"},"outputs":[],"source":["# 7. Save the model\n","model.save_pretrained(\"qwen3.5_translation_lora\")\n","tokenizer.save_pretrained(\"qwen3.5_translation_lora\")"]},{"cell_type":"code","source":["from unsloth import FastLanguageModel\n","FastLanguageModel.for_inference(model) # Enable 2x faster inference\n","\n","def test_translation(sentence: str) -> str:\n","    PROMPT_TEMPLATE: str = (\n","        \"### Instruction:\\n\"\n","        \"Translate the Bangla sentence to Bangla Sign Language (BdSL) gloss.\\n\\n\"\n","        \"### Input:\\n\"\n","        \"{source}\\n\\n\"\n","        \"### Response:\\n\"\n","        \"{target}\"\n","    )\n","    messages: str = PROMPT_TEMPLATE.format(source=sentence, target=\"\")\n","    inputs = tokenizer([messages], return_tensors=\"pt\").to(\"cuda\")\n","\n","    outputs = model.generate(**inputs, max_new_tokens=128, use_cache=True)\n","    return tokenizer.batch_decode(outputs)[0]\n","\n","# Test on a sentence from the VAL set, not the TRAIN set\n","print(test_translation(\"আমি ভাত খাই।\"))"],"metadata":{"id":"wGx94_nyK3JK"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","from typing import List, Dict, Any\n","\n","def plot_training_history(trainer: Any) -> None:\n","    history: List[Dict[str, Any]] = trainer.state.log_history\n","\n","    train_loss: List[float] = [x[\"loss\"] for x in history if \"loss\" in x]\n","    train_steps: List[int] = [x[\"step\"] for x in history if \"loss\" in x]\n","\n","    val_loss: List[float] = [x[\"eval_loss\"] for x in history if \"eval_loss\" in x]\n","    val_steps: List[int] = [x[\"step\"] for x in history if \"eval_loss\" in x]\n","\n","    plt.figure(figsize=(10, 6))\n","    plt.plot(train_steps, train_loss, label=\"Training Loss\", color=\"blue\", alpha=0.7)\n","    plt.plot(val_steps, val_loss, label=\"Validation Loss\", color=\"red\", marker=\"o\")\n","\n","    plt.title(\"Bangla-to-Gloss Training Progress\")\n","    plt.xlabel(\"Steps\")\n","    plt.ylabel(\"Loss\")\n","    plt.legend()\n","    plt.grid(True, linestyle=\"--\", alpha=0.6)\n","    plt.show()\n","\n","plot_training_history(trainer)"],"metadata":{"id":"oiHaHrLpkMJj"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["!pip install evaluate sacrebleu chrfscore"],"metadata":{"id":"XgZadinpkNGL"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import evaluate\n","import pandas as pd\n","from tqdm import tqdm\n","from typing import Dict, List, Any\n","from unsloth import FastLanguageModel\n","\n","# Load metrics\n","bleu: Any = evaluate.load(\"bleu\")\n","chrf: Any = evaluate.load(\"chrf\")\n","\n","def evaluate_on_test_set(test_csv_path: str, model: Any, tokenizer: Any) -> Dict[str, float]:\n","    # 1. Load data\n","    df_test: pd.DataFrame = pd.read_csv(test_csv_path)\n","    predictions: List[str] = []\n","    references: List[List[str]] = []\n","\n","    print(f\"Starting evaluation on {len(df_test)} samples...\")\n","    FastLanguageModel.for_inference(model) # Ensure 2x faster inference is active\n","\n","    for _, row in tqdm(df_test.iterrows(), total=len(df_test)):\n","        # 2. Prepare the Input (Match your training prompt exactly)\n","        source_text: str = str(row[\"text\"])\n","        # We leave 'target' empty to let the model complete the gloss\n","        prompt: str = (\n","            f\"### Instruction:\\nTranslate the Bangla sentence to Bangla Sign Language (BdSL) gloss.\\n\\n\"\n","            f\"### Input:\\n{source_text}\\n\\n\"\n","            f\"### Response:\\n\"\n","        )\n","\n","        inputs = tokenizer([prompt], return_tensors=\"pt\").to(\"cuda\")\n","\n","        # 3. Generate with constraints\n","        outputs = model.generate(\n","            **inputs,\n","            max_new_tokens=256,\n","            use_cache=True,\n","            pad_token_id=tokenizer.eos_token_id\n","        )\n","\n","        # 4. Extract only the generated Response\n","        full_output: str = tokenizer.batch_decode(outputs, skip_special_tokens=True)[0]\n","        # Split by the Response header to isolate the gloss\n","        if \"### Response:\\n\" in full_output:\n","            response: str = full_output.split(\"### Response:\\n\")[-1].strip()\n","        else:\n","            response: str = full_output.strip()\n","\n","        predictions.append(response)\n","        references.append([str(row[\"gloss\"])])\n","\n","    # 5. Compute Metrics\n","    bleu_results: Dict[str, Any] = bleu.compute(predictions=predictions, references=references)\n","    chrf_results: Dict[str, Any] = chrf.compute(predictions=predictions, references=references)\n","\n","    return {\n","        \"bleu_score\": bleu_results[\"bleu\"] * 100,\n","        \"chrf_score\": chrf_results[\"score\"]\n","    }\n"],"metadata":{"id":"ucj6wc54keTK"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["results = evaluate_on_test_set(\"/content/test.csv\", model, tokenizer)\n","print(f\"\\n--- Test Results ---\\nBLEU: {results['bleu_score']:.2f}\\nchrF: {results['chrf_score']:.2f}\")"],"metadata":{"id":"ZWbkpwKazzpQ"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["!zip -r qwen-9b-lora.zip /content/outputs/\n","from google.colab import files\n","files.download(\"qwen-9b-lora.zip\")"],"metadata":{"id":"4Tl5PA6g8Hlp"},"execution_count":null,"outputs":[]}],"metadata":{"accelerator":"GPU","colab":{"gpuType":"T4","provenance":[]},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}